# =============================================================================
#  Mercati Soresina — variabili ambiente
# =============================================================================
#
#  Copia questo file in `.env.local` per lo sviluppo locale.
#  In produzione (e in staging) le variabili vanno settate sul dashboard
#  di Vercel:  Settings > Environment Variables.
#
#  Per ogni variabile, Vercel permette di selezionare su quali ambienti
#  applicarla: Production, Preview, Development. Vedi DEPLOY.md per il
#  setup completo di dev/staging/prod.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — OBBLIGATORIO
# -----------------------------------------------------------------------------
# Le credenziali del progetto Supabase. Le trovi su:
#   https://app.supabase.com -> Settings -> API
#
# Per staging crea un SECONDO progetto Supabase (gratis fino a 2 progetti su
# free tier) e incolla QUI sotto le sue credenziali in .env.local per testare
# localmente. In Vercel metti le credenziali del progetto prod per l'env
# "Production" e quelle del progetto staging per l'env "Preview".
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# Site URL — opzionale ma consigliato
# -----------------------------------------------------------------------------
# URL canonico del sito per i meta tag OG/Twitter e i redirect auth. Se non
# impostato, Next.js usa VERCEL_URL (auto su Vercel) o localhost in dev.
#
#   dev        -> http://localhost:3000
#   staging    -> https://soresina-mercati-staging.vercel.app  (esempio)
#   produzione -> https://soresina-mercati.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Sentry — error tracking (opzionale, consigliato in prod)
# -----------------------------------------------------------------------------
# DSN pubblico del progetto Sentry. Lo trovi su:
#   https://sentry.io -> Settings -> Projects -> [project] -> Client Keys
#
# Se lasciato vuoto, Sentry non inizializza e non riporta errori — utile
# in locale per non inquinare il quota del piano free (5k errori/mo).
NEXT_PUBLIC_SENTRY_DSN=

# Per l'upload dei source maps in build (serve per avere gli stack trace
# leggibili). Questi vanno solo su Vercel (NON in .env.local): sono credenziali
# di organizzazione + auth token con scope "project:releases".
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Vercel Analytics — nessuna variabile
# -----------------------------------------------------------------------------
# Vercel Analytics si abilita via pacchetto `@vercel/analytics` (gia' installato)
# e non richiede env vars. Funziona solo su deploy Vercel in produzione.
